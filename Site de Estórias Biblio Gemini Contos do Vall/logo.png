<header class="max-w-6xl mx-auto mb-10 text-center">
    <img src="logo.png" alt="BiblioGemini - Contos do Vall" class="mx-auto mb-4 max-w-[300px] w-full h-auto">
    <p class="text-slate-500 mb-6">Explore e compartilhe histórias incríveis geradas pelo Gemini</p>
    
    <div class="flex flex-col md:flex-row gap-4 justify-center items-center">
        <input type="text" id="searchInput" placeholder="Pesquisar por título ou tema..." 
            class="w-full md:w-96 p-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-indigo-400 outline-none transition shadow-sm">
        
        <button onclick="toggleForm()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-lg font-semibold transition shadow-lg w-full md:w-auto">
            + Nova História
        </button>
    </div>
</header>